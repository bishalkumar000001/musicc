# Telegram API Credentials
# Get from https://my.telegram.org/apps
API_ID=your_api_id_here
API_HASH=your_api_hash_here

# Bot Token
# Get from @BotFather on Telegram
BOT_TOKEN=your_bot_token_here

# Assistant Account (optional)
ASSISTANT_ACCOUNT=your_assistant_account_username_here

# Database
MONGO_DB_URI=mongodb://localhost:27017
DB_NAME=music_bot

# Admin Configuration
OWNER_ID=your_owner_id_here
ADMIN_IDS=your_admin_id_here,another_admin_id_here

# Logger Configuration (optional)
# Channel ID where bot logs important events
LOGGER_CHANNEL_ID=your_logger_channel_id_here
